# Slack Bot OAuth Token (starts with xoxb-)
# Get it from: https://api.slack.com/apps -> Your App -> OAuth & Permissions
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# Slack App-Level Token (starts with xapp-) - for Socket Mode / real-time
# Get it from: Basic Information -> App-Level Tokens (scope: connections:write)
SLACK_APP_TOKEN=xapp-your-app-token-here
