OPENAI_API_KEY=sk-...
PINECONE_API_KEY=...
PINECONE_INDEX=sop-index
PINECONE_INDEX_HOST=https://sop-index-xxx.svc.pinecone.io
# Namespace for organizing vectors (default: "default")
PINECONE_NAMESPACE=default
# TOP_K controls how many SOP docs are retrieved per message (default: 3)
TOP_K=3
# Feedback examples for few-shot learning (default: 6 = 3 false_positive + 3 correct)
# FEEDBACK_MAX_EXAMPLES=6
# Slack Bot OAuth Token (starts with xoxb-)
# Get it from: https://api.slack.com/apps -> Your App -> OAuth & Permissions
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# Slack App-Level Token (starts with xapp-) - for Socket Mode / real-time
# Get it from: Basic Information -> App-Level Tokens (scope: connections:write)
SLACK_APP_TOKEN=xapp-your-app-token-here

# Notion (for notion_connector)
# Create at https://www.notion.so/my-integrations, share pages with the integration
NOTION_API_KEY=secret_your_integration_token

# Optional: Custom onboarding message for new users (DM'd when they first post)
# ONBOARDING_MESSAGE=Your custom welcome message here...

# Optional: Set to 1 to log slash command invocations (for debugging)
# SLACK_DEBUG=1
